{
  "name": "insurance-workflow-automation",
  "version": "1.0.0",
  "description": "Insurance Workflow Automation Software with complete CI/CD pipeline",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --verbose",
    "test:unit": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/unit --coverage",
    "test:integration": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/integration --coverage --forceExit",
    "test:system": "cross-env NODE_OPTIONS=--experimental-vm-modules jest tests/system --coverage",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --testPathIgnorePatterns=tests/system --coverageReporters=text --coverageReporters=html --coverageReporters=json-summary",
    "coverage:check": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --coverageThreshold=\"{\\\"global\\\":{\\\"branches\\\":75,\\\"functions\\\":75,\\\"lines\\\":75,\\\"statements\\\":75}}\"",
    "lint": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern coverage --ignore-pattern uploads --format json --output-file lint-report.json || true",
    "lint:fix": "eslint . --ext .js --ignore-pattern node_modules --ignore-pattern coverage --ignore-pattern uploads --fix",
    "security": "npm audit --json > security-report.json && npm audit",
    "security:check": "npm audit --audit-level=high || echo Security check completed",
    "build": "echo Build successful - No compilation needed for Node.js",
    "ci": "npm run build && npm run test && npm run coverage:check && npm run lint && npm run security"
  },
  "keywords": [
    "insurance",
    "workflow",
    "automation",
    "kyc",
    "node",
    "express"
  ],
  "author": "The Final Commit",
  "license": "ISC", 
  "dependencies": {
    "axios": "^1.6.0", 
    "bcryptjs": "^3.0.2", 
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0", 
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2", 
    "mysql2": "^3.15.3", 
    "pdfkit": "^0.17.2",
    "pdf2pic": "^3.0.4",
    "tesseract.js": "^6.0.1",
    "twilio": "^5.10.3" 
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@jest/globals": "^29.7.0", 
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0", 
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jest": "^27.6.0",
    "jest": "^30.2.0", 
    "jest-environment-node": "^30.2.0",
    "nodemon": "^3.1.7",
    "snyk": "^1.1266.0",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "controllers/**/*.js",
      "!controllers/authController.js",
      "middleware/**/*.js",
      "models/**/*.js",
      "utils/otpHelper.js",
      "!server.js",
      "!config/**",
      "!routes/**",
      "!utils/ocrHelper.js",
      "!utils/twilioClient.js",
      "!utils/verifyHelper.js",
      "!**/node_modules/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 75,
        "functions": 75,
        "lines": 75,
        "statements": 75
      }
    },
    "testPathIgnorePatterns": ["tests/system"],
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "transform": {},
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "testTimeout": 10000
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
